---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="About Monica Hernandez"
  description="From Medellín to Fortune 500 — the story behind Monica Hernandez, Founder & CEO of MAS Global."
  current="about"
>

  <!-- Hero -->
  <section class="about-hero fade-in" aria-labelledby="about-h1">
    <div class="container">
      <div class="eyebrow"><span class="eyebrow-text">About Monica</span></div>
      <h1 id="about-h1">My story to become <span class="more-accent">MORE…</span></h1>
      <p class="about-sub">From a software engineering student in Medellín to Founder &amp; CEO of MAS Global — a journey of reinvention, resilience, and giving back.</p>
    </div>
  </section>

  <!-- MORE sticky ticker -->
  <nav class="more-ticker" aria-label="Chapter navigation">
    <button type="button" class="letter-dot active" data-letter="M" aria-label="Jump to chapter M — Medellín">M</button>
    <button type="button" class="letter-dot" data-letter="O" aria-label="Jump to chapter O — Oracle">O</button>
    <button type="button" class="letter-dot" data-letter="R" aria-label="Jump to chapter R — Roots & Reinvestment">R</button>
    <button type="button" class="letter-dot" data-letter="E" aria-label="Jump to chapter E — Empowerment">E</button>
  </nav>

  <!-- M — Medellín -->
  <section class="more-chapter" data-letter="M" aria-labelledby="more-m-h2">
    <div class="more-letter-bg" aria-hidden="true">M</div>
    <div class="container">
      <div class="more-chapter-grid fade-in">
        <div class="more-chapter-text">
          <div class="chapter-meta">
            <span class="chapter-letter">M</span>
            <span class="chapter-kicker">Medellín, Colombia</span>
          </div>
          <h2 id="more-m-h2">Path to software engineering &amp; the U.S.</h2>
          <p>Born and raised in Medellín, Colombia. Monica earned a full academic scholarship to study software engineering at EAFIT — the opportunity that would change everything.</p>
          <p>That single scholarship became the seed of a 20-year journey that would take her from a classroom in Antioquia to enterprise tech projects across Europe and the United States.</p>
        </div>
        <div class="more-chapter-visual">
          <img src="/Images/Fotos%20Monica/Monica%20Oficina%20Medellin.jpg" alt="Monica Hernandez en Medellín, Colombia" />
        </div>
      </div>
    </div>
  </section>

  <!-- O — Oracle -->
  <section class="more-chapter" data-letter="O" aria-labelledby="more-o-h2">
    <div class="more-letter-bg" aria-hidden="true">O</div>
    <div class="container">
      <div class="more-chapter-grid reverse fade-in">
        <div class="more-chapter-text">
          <div class="chapter-meta">
            <span class="chapter-letter">O</span>
            <span class="chapter-kicker">Oracle Consulting</span>
          </div>
          <h2 id="more-o-h2">Out of my comfort zone in corporate America.</h2>
          <p>At 21, Monica landed in the United States. She built her IT career in Texas, then joined Oracle as a consultant — traveling across the U.S. and Europe leading enterprise-scale technology projects for Fortune 500 clients.</p>
          <p>20+ years learning, from the inside, how the world's largest organizations actually think, decide, and build.</p>
        </div>
        <div class="more-chapter-visual">
          <img src="/Images/Fotos%20Monica/Monica%20in%20Oracle.jpg" alt="Monica Hernandez during her years at Oracle" />
        </div>
      </div>
    </div>
  </section>

  <!-- R — Roots / MAS Global -->
  <section class="more-chapter" data-letter="R" aria-labelledby="more-r-h2">
    <div class="more-letter-bg" aria-hidden="true">R</div>
    <div class="container">
      <div class="more-chapter-grid fade-in">
        <div class="more-chapter-text">
          <div class="chapter-meta">
            <span class="chapter-letter">R</span>
            <span class="chapter-kicker">Roots &amp; Reinvestment · MAS Global</span>
          </div>
          <h2 id="more-r-h2">A company built on a belief — and a scholarship that gave back.</h2>
          <p>In 2013, Monica founded MAS Global on a simple idea: elite talent exists everywhere, and enterprise deserves access to it. Today MAS Global serves Fortune 500 brands, connecting U.S. companies with top tech talent across Latin America.</p>
          <p>The scholarship that changed her life at 18 now bears her company's name. The <strong>MAS Global–EAFIT Scholarship</strong> gives the next generation of Colombian engineers the same opportunity — and fuels U.S. tech teams with world-class talent. Her story, full circle.</p>
        </div>
        <div class="more-chapter-visual">
          <img src="/Images/Fotos%20Monica/Monica%20award%20in%20EAFIT.jpg" alt="Monica Hernandez at EAFIT University, where her scholarship was born" />
        </div>
      </div>
    </div>
  </section>

  <!-- E — Empowerment -->
  <section class="more-chapter" data-letter="E" aria-labelledby="more-e-h2">
    <div class="more-letter-bg" aria-hidden="true">E</div>
    <div class="container">
      <div class="more-chapter-grid reverse fade-in">
        <div class="more-chapter-text">
          <div class="chapter-meta">
            <span class="chapter-letter">E</span>
            <span class="chapter-kicker">Empowerment · Beyond the Company</span>
          </div>
          <h2 id="more-e-h2">Platform. Podcast. Purpose.</h2>
          <p>Host of the <strong>MAS Impact Podcast</strong>, where Monica sits down with the leaders shaping AI, enterprise tech, and inclusive growth.</p>
          <p>Founder of the <strong>MAS Future Foundation</strong>, dedicated to upskilling the next generation of women and Latinos entering the technology industry. Forbes Technology Council member. Bloomberg Línea's 100 Most Influential Latinos in Tech.</p>
        </div>
        <div class="more-chapter-visual">
          <img src="/Images/Fotos%20Monica/Monicas%20miling.png" alt="Monica Hernandez — Founder & CEO, MAS Global" />
        </div>
      </div>
    </div>
  </section>

  <!-- Awards -->
  <section class="awards-section" aria-labelledby="awards-h2">
    <div class="container">
      <div class="eyebrow fade-in"><span class="eyebrow-text">Awards &amp; Honors</span></div>
      <h2 id="awards-h2" class="fade-in">Recognition</h2>
      <div class="awards-grid reveal-stagger">

        <div class="award-card">
          <div class="award-icon">
            <img src="/Images/Monica's%20awards/Bloomberg-Linea-square-1.png" alt="Bloomberg Línea" />
          </div>
          <p class="award-name">100 Most Influential Latinos</p>
          <p class="award-org">Bloomberg Línea</p>
        </div>

        <div class="award-card">
          <div class="award-icon">
            <img src="/Images/Monica's%20awards/EnterprisingWomen.png" alt="Enterprising Women of the Year" />
          </div>
          <p class="award-name">Enterprising Women of the Year</p>
          <p class="award-org">Enterprising Women Magazine</p>
        </div>

        <div class="award-card">
          <div class="award-icon">
            <img src="/Images/Monica's%20awards/EY-Entrepeneurial-Winning-Women.png" alt="EY Entrepreneurial Winning Women" />
          </div>
          <p class="award-name">EY Entrepreneurial Winning Women™</p>
          <p class="award-org">North America Class of 2021</p>
        </div>

        <div class="award-card">
          <div class="award-icon">
            <img src="/Images/Monica's%20awards/HITEC100.png" alt="HITEC 100 Awardee" />
          </div>
          <p class="award-name">HITEC 100 Awardee</p>
          <p class="award-org">U.S. &amp; Global</p>
        </div>

        <div class="award-card">
          <div class="award-icon">
            <img src="/Images/Monica's%20awards/women2watch-jp-morgan-002%20(1).png" alt="Women 2 Watch — JPMorgan Chase" />
          </div>
          <p class="award-name">Women 2 Watch</p>
          <p class="award-org">JPMorgan Chase</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Closing -->
  <section class="closing-band" aria-label="About Monica personally">
    <div class="container fade-in">
      <p>Tampa, Florida. Two kids. One belief: technology's highest purpose is expanding access — to opportunity, to markets, to the rooms where decisions get made.</p>
    </div>
  </section>

  <script>
    function initAbout() {
      const dots = document.querySelectorAll('.more-ticker .letter-dot');
      const chapters = document.querySelectorAll('.more-chapter');

      const setActive = (letter) => {
        dots.forEach((d) => d.classList.toggle('active', d.dataset.letter === letter));
      };

      // Highlight active letter as user scrolls into chapter
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('in-view');
                const letter = e.target.dataset.letter;
                if (letter) setActive(letter);
              }
            });
          },
          { rootMargin: '-40% 0px -40% 0px', threshold: 0 }
        );
        chapters.forEach((c) => io.observe(c));
      }

      // Click on a letter dot → smooth scroll to its chapter
      const lenis = window.__lenis;
      const header = document.getElementById('site-header');
      const headerOffset = (header ? header.offsetHeight : 68) + 16;

      dots.forEach((dot) => {
        dot.addEventListener('click', () => {
          const letter = dot.dataset.letter;
          const target = document.querySelector('.more-chapter[data-letter="' + letter + '"]');
          if (!target) return;
          const top = target.getBoundingClientRect().top + window.scrollY - headerOffset;
          if (lenis && typeof lenis.scrollTo === 'function') {
            lenis.scrollTo(top, { duration: 1.2, easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)) });
          } else {
            window.scrollTo({ top, behavior: 'smooth' });
          }
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAbout);
    } else {
      initAbout();
    }
  </script>

</Layout>
