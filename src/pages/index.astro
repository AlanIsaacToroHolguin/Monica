---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Monica Hernandez — Keynote Speaker & CEO, MAS Global"
  description="Monica Hernandez — Founder & CEO of MAS Global, Forbes Technology Council member, keynote speaker with 20+ years of enterprise technology leadership."
  current="home"
>

  <!-- Hero -->
  <section class="hero" aria-label="Monica Hernandez — keynote speaker">
    <div class="hero-bg" id="hero-home-bg" style="background-image:url('/Images/Enterprise%20and%20event%20logos/Monica%20HeadshotBackground.jpg');background-size:cover;background-position:center;"></div>
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="container">
      <div class="hero-content">
        <div class="hero-eyebrow"><span>Bloomberg Línea · Top 100 Hispanics in Tech</span></div>
        <h1>From Medellín<br />to the Fortune 500.</h1>
        <p class="hero-subheadline">Founder &amp; CEO of MAS Global. Keynote speaker on AI, leadership, and how enterprise really gets built.</p>
        <div class="hero-ctas">
          <a class="btn btn-red btn-pill" href="/book" role="button">Book Monica</a>
          <a class="btn btn-ghost" href="/speaking" role="button">View Speaking Topics</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Awards Row -->
  <section class="awards-row" aria-label="Awards and recognition">
    <div class="awards-inner reveal-stagger">

      <div class="award-item edge-left" tabindex="0">
        <img class="award-thumb" src="/Images/Monica's%20awards/Bloomberg-Linea-square-1.png" alt="Bloomberg Línea — 100 Most Influential Latinos" />
        <div class="award-popup" role="tooltip">
          <img class="award-popup-badge" src="/Images/Monica's%20awards/Bloomberg-Linea-square-1.png" alt="" />
          <div class="award-popup-text">
            <span class="award-popup-eyebrow">Featured Recognition</span>
            <span class="award-popup-name">100 Most Influential Latinos in Technology</span>
            <span class="award-popup-source">Bloomberg Línea</span>
          </div>
        </div>
      </div>

      <div class="award-item" tabindex="0">
        <img class="award-thumb" src="/Images/Monica's%20awards/EnterprisingWomen.png" alt="Enterprising Women of the Year" />
        <div class="award-popup" role="tooltip">
          <img class="award-popup-badge" src="/Images/Monica's%20awards/EnterprisingWomen.png" alt="" />
          <div class="award-popup-text">
            <span class="award-popup-eyebrow">Award</span>
            <span class="award-popup-name">Enterprising Women of the Year</span>
            <span class="award-popup-source">Enterprising Women Magazine</span>
          </div>
        </div>
      </div>

      <div class="award-item" tabindex="0">
        <img class="award-thumb" src="/Images/Monica's%20awards/EY-Entrepeneurial-Winning-Women.png" alt="EY Entrepreneurial Winning Women" />
        <div class="award-popup" role="tooltip">
          <img class="award-popup-badge" src="/Images/Monica's%20awards/EY-Entrepeneurial-Winning-Women.png" alt="" />
          <div class="award-popup-text">
            <span class="award-popup-eyebrow">Award</span>
            <span class="award-popup-name">EY Entrepreneurial Winning Women&trade;</span>
            <span class="award-popup-source">North America Class of 2021</span>
          </div>
        </div>
      </div>

      <div class="award-item" tabindex="0">
        <img class="award-thumb" src="/Images/Monica's%20awards/HITEC100.png" alt="HITEC 100 Awardee" />
        <div class="award-popup" role="tooltip">
          <img class="award-popup-badge" src="/Images/Monica's%20awards/HITEC100.png" alt="" />
          <div class="award-popup-text">
            <span class="award-popup-eyebrow">Honoree</span>
            <span class="award-popup-name">HITEC 100 Awardee</span>
            <span class="award-popup-source">U.S. &amp; Global</span>
          </div>
        </div>
      </div>

      <div class="award-item" tabindex="0">
        <img class="award-thumb" src="/Images/Monica's%20awards/women2watch-jp-morgan-002%20(1).png" alt="Women 2 Watch — JPMorgan Chase" />
        <div class="award-popup" role="tooltip">
          <img class="award-popup-badge" src="/Images/Monica's%20awards/women2watch-jp-morgan-002%20(1).png" alt="" />
          <div class="award-popup-text">
            <span class="award-popup-eyebrow">Recognition</span>
            <span class="award-popup-name">Women 2 Watch</span>
            <span class="award-popup-source">JPMorgan Chase</span>
          </div>
        </div>
      </div>

      <div class="award-item edge-right" tabindex="0">
        <img class="award-thumb" src="/Images/Monica's%20awards/Forbes%20(1).png" alt="Forbes Technology Council" />
        <div class="award-popup" role="tooltip">
          <img class="award-popup-badge" src="/Images/Monica's%20awards/Forbes%20(1).png" alt="" />
          <div class="award-popup-text">
            <span class="award-popup-eyebrow">Member Since 2021</span>
            <span class="award-popup-name">Forbes Technology Council</span>
            <span class="award-popup-source">Invite-Only Tech Leadership Community</span>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Introduction -->
  <section class="intro-section" aria-labelledby="home-intro-h2">
    <div class="container">
      <div class="intro-grid fade-in">
        <div class="intro-text">
          <div class="eyebrow"><span class="eyebrow-text">About Monica</span></div>
          <h2 id="home-intro-h2">Engineer. Consultant. Founder.<br />She's lived every side of enterprise tech.</h2>
          <p>From Medellín to Oracle to founding MAS Global in 2013 — Monica has spent 20+ years building, advising, and leading inside Fortune 500 organizations.</p>
          <p>She speaks from that experience. Not around it.</p>
          <a class="text-link" href="/about" style="margin-top: 8px; display: inline-block;">Read her full story →</a>
        </div>
        <div class="intro-image">
          <img src="/Images/Fotos%20Monica/Definitiveabout.png" alt="Monica Hernandez, Founder and CEO of MAS Global" />
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Band -->
  <section class="stats-band fade-in" aria-label="Monica Hernandez by the numbers">
    <div class="container">
      <div class="stats-grid reveal-stagger">
        <div class="stat-item">
          <div class="stat-number" data-count="20" data-suffix="+">0</div>
          <div class="stat-label">Years in<br />Enterprise Tech</div>
        </div>
        <div class="stat-item">
          <div class="stat-number" data-count="100" data-suffix="+">0</div>
          <div class="stat-label">Keynotes &amp;<br />Speaking Stages</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">F<span class="accent">500</span></div>
          <div class="stat-label">Trusted by<br />Fortune 500 Leaders</div>
        </div>
        <div class="stat-item">
          <div class="stat-number" data-count="3">0</div>
          <div class="stat-label">Countries<br />U.S. · Colombia · Canada</div>
        </div>
      </div>
    </div>
  </section>

  <!-- As Seen In -->
  <section class="press-band" aria-label="Media appearances and press">
    <div class="container">
      <div class="press-eyebrow-wrap fade-in">
        <span class="press-kicker">As Seen In</span>
        <div class="press-headline">Featured by the press<br />that shapes the industry.</div>
      </div>
    </div>
    <div class="press-track-wrap">
      <div class="press-track" aria-hidden="false">
        <div class="press-item"><img src="/Images/Enterprise%20and%20event%20logos/forbes-technology-council-logo.webp" alt="Forbes Technology Council" /></div>
        <div class="press-item"><img src="/Images/Enterprise%20and%20event%20logos/usa%20today%20logo.jpg" alt="USA Today" /></div>
        <div class="press-item"><img src="/Images/Enterprise%20and%20event%20logos/tampa%20bay%20business%20journal%20logo.webp" alt="Tampa Bay Business Journal" /></div>
        <div class="press-item"><img src="/Images/Enterprise%20and%20event%20logos/CharlotteBusinessJournal%20logo.png" alt="Charlotte Business Journal" /></div>
        <div class="press-item"><img src="/Images/Enterprise%20and%20event%20logos/logo-portafolio-colombia.jpg.webp" alt="Portafolio Colombia" /></div>
        <div class="press-item"><span>Latino Business Action Network</span></div>
        <div class="press-item"><span>Historias Inspiradoras</span></div>
        <div class="press-item"><img src="/Images/Enterprise%20and%20event%20logos/forbes-technology-council-logo.webp" alt="" aria-hidden="true" /></div>
        <div class="press-item"><img src="/Images/Enterprise%20and%20event%20logos/usa%20today%20logo.jpg" alt="" aria-hidden="true" /></div>
        <div class="press-item"><img src="/Images/Enterprise%20and%20event%20logos/tampa%20bay%20business%20journal%20logo.webp" alt="" aria-hidden="true" /></div>
        <div class="press-item"><img src="/Images/Enterprise%20and%20event%20logos/CharlotteBusinessJournal%20logo.png" alt="" aria-hidden="true" /></div>
        <div class="press-item"><img src="/Images/Enterprise%20and%20event%20logos/logo-portafolio-colombia.jpg.webp" alt="" aria-hidden="true" /></div>
        <div class="press-item" aria-hidden="true"><span>Latino Business Action Network</span></div>
        <div class="press-item" aria-hidden="true"><span>Historias Inspiradoras</span></div>
      </div>
    </div>
  </section>

  <!-- Speaking Themes -->
  <section class="section" aria-labelledby="home-themes-h2">
    <div class="container">
      <div class="eyebrow fade-in"><span class="eyebrow-text">Speaking Topics</span></div>
      <h2 id="home-themes-h2" class="fade-in">Three topics.<br />One thread: clarity.</h2>
      <div class="cards-grid reveal-stagger">

        <article class="card">
          <div class="card-num" aria-hidden="true">01</div>
          <h3>AI in the Enterprise</h3>
          <p>Where AI creates real value — and where it doesn't. Grounded in 20+ years of delivery.</p>
          <a class="text-link" href="/speaking">Learn more →</a>
        </article>

        <article class="card">
          <div class="card-num" aria-hidden="true">02</div>
          <h3>Leadership That Scales</h3>
          <p>Building teams that perform across cultures, time zones, and complexity.</p>
          <a class="text-link" href="/speaking">Learn more →</a>
        </article>

        <article class="card">
          <div class="card-num" aria-hidden="true">03</div>
          <h3>Pitch a Corporation</h3>
          <p>What enterprise buyers actually need. Monica has been on both sides of the table.</p>
          <a class="text-link" href="/speaking">Learn more →</a>
        </article>

      </div>
    </div>
  </section>

  <!-- In the Press (articles ABOUT Monica) -->
  <section class="articles-section" aria-labelledby="press-h2">
    <div class="container">
      <div class="articles-header fade-in">
        <div class="eyebrow eyebrow-center"><span class="eyebrow-text">In the Press</span></div>
        <h2 id="press-h2">As featured in.</h2>
        <p>Recent profiles and features in the publications shaping the conversation in tech, leadership, and inclusive growth.</p>
      </div>
      <div class="articles-grid reveal-stagger">

        <a class="article-card" href="https://www.bizjournals.com/bizwomen/news/profiles-strategies/2024/12/mas-global-ceo-monica-hernandez-tech-innovation.html" target="_blank" rel="noopener noreferrer" aria-label="Read on The Business Journals">
          <div class="article-thumb">
            <img src="https://images.unsplash.com/photo-1556761175-5973dc0f32e7?w=800&h=600&fit=crop&q=80" alt="" />
            <span class="article-publication">Business<br />Journals</span>
          </div>
          <h3>MAS Global CEO Monica Hernandez on driving tech innovation</h3>
        </a>

        <a class="article-card" href="https://www.usatoday.com/story/special/contributor-content/2024/07/18/monica-hernandez-empowering-u-s-firms-with-colombian-cloud-and-ai-talent-upskilling-latinos-in-tech/74454765007/" target="_blank" rel="noopener noreferrer" aria-label="Read on USA Today">
          <div class="article-thumb">
            <img src="https://images.unsplash.com/photo-1573164713988-8665fc963095?w=800&h=600&fit=crop&q=80" alt="" />
            <span class="article-publication">USA Today</span>
          </div>
          <h3>Empowering U.S. Firms with Colombian Cloud and AI Talent</h3>
        </a>

        <a class="article-card" href="https://forbes.co/brandvoice/mas-global-una-historia-inspiradora-hace-brillar-a-colombia-en-la-industria-del-software" target="_blank" rel="noopener noreferrer" aria-label="Read on Forbes Colombia">
          <div class="article-thumb">
            <img src="https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?w=800&h=600&fit=crop&q=80" alt="" />
            <span class="article-publication">Forbes Colombia</span>
          </div>
          <h3>MAS Global, una historia inspiradora hace brillar a Colombia en la industria del software</h3>
        </a>

        <a class="article-card" href="https://blogs.portafolio.co/negocios-e-inspiracion/monica-hernandez-de-un-barrio-humilde-a-la-elite-de-la-tecnologia/" target="_blank" rel="noopener noreferrer" aria-label="Read on Portafolio Colombia">
          <div class="article-thumb">
            <img src="https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?w=800&h=600&fit=crop&q=80" alt="" />
            <span class="article-publication">Portafolio<br />Colombia</span>
          </div>
          <h3>Mónica Hernández: de un barrio humilde a la élite de la tecnología</h3>
        </a>

        <a class="article-card" href="https://councils.forbes.com/profile/Monica-Hernandez-Founder-CEO-MAS-Global/6908ed9b-3b81-4858-bf5a-9e4b8d70ed40" target="_blank" rel="noopener noreferrer" aria-label="View Monica's Forbes Tech Council profile">
          <div class="article-thumb">
            <img src="https://images.unsplash.com/photo-1551836022-deb4988cc6c0?w=800&h=600&fit=crop&q=80" alt="" />
            <span class="article-publication">Forbes</span>
          </div>
          <h3>Forbes Technology Council — Monica Hernandez, Founder &amp; CEO of MAS Global</h3>
        </a>

      </div>
    </div>
  </section>

  <!-- Words by Monica (articles BY her — thought leadership) -->
  <section class="words-section" aria-labelledby="words-h2">
    <div class="container">
      <div class="words-header fade-in">
        <div class="eyebrow eyebrow-center"><span class="eyebrow-text">Words by Monica</span></div>
        <h2 id="words-h2">Thought leadership,<br />on the record.</h2>
        <p>Articles, op-eds, and contributions from Monica on the Forbes Technology Council.</p>
      </div>

      <div class="words-list reveal-stagger">

        <a class="word-row" href="https://www.forbes.com/councils/forbestechcouncil/2024/04/23/transforming-tech-how-latams-nearshoring-powers-data-ai-and-beyond/" target="_blank" rel="noopener noreferrer">
          <div class="word-meta">
            <div class="word-year">2024</div>
            <div class="word-pub">Forbes Tech Council</div>
          </div>
          <div>
            <div class="word-title">Transforming Tech: How LATAM's Nearshoring Powers Data, AI, and Beyond</div>
            <span class="word-tag">By Monica Hernandez</span>
          </div>
          <div class="word-arrow" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </div>
        </a>

        <a class="word-row" href="https://www.forbes.com/councils/forbestechcouncil/2022/04/05/igniting-the-ecosystem-for-women-entrepreneurs/" target="_blank" rel="noopener noreferrer">
          <div class="word-meta">
            <div class="word-year">2022</div>
            <div class="word-pub">Forbes Tech Council</div>
          </div>
          <div>
            <div class="word-title">Igniting the Ecosystem for Women Entrepreneurs</div>
            <span class="word-tag">By Monica Hernandez</span>
          </div>
          <div class="word-arrow" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </div>
        </a>

        <a class="word-row" href="https://www.forbes.com/councils/forbestechcouncil/2025/12/05/expert-tips-for-staying-current-in-todays-tech-driven-roles/" target="_blank" rel="noopener noreferrer">
          <div class="word-meta">
            <div class="word-year">2025</div>
            <div class="word-pub">Forbes Tech Council</div>
          </div>
          <div>
            <div class="word-title">Expert Tips for Staying Current in Today's Tech-Driven Roles</div>
            <span class="word-tag">Contribution by Monica Hernandez</span>
          </div>
          <div class="word-arrow" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="testimonials-band" aria-labelledby="home-testimonials-h2">
    <div class="container">
      <div class="eyebrow fade-in">
        <span class="eyebrow-text">What Leaders Are Saying</span>
      </div>
      <h2 id="home-testimonials-h2" class="fade-in">What leaders<br />are saying.</h2>
      <div class="pq-grid reveal-stagger">

        <div class="pullquote">
          <div class="pq-mark" aria-hidden="true">&ldquo;</div>
          <blockquote>Monica doesn't just inspire — she gives you a framework you can use on Monday morning.</blockquote>
          <cite>
            <span class="cite-name">Sarah M.</span>
            <span class="cite-role">VP, Fortune 500 Tech Company</span>
          </cite>
        </div>

        <div class="pullquote">
          <div class="pq-mark" aria-hidden="true">&ldquo;</div>
          <blockquote>She speaks from lived experience — and it shows. The response from our team was extraordinary.</blockquote>
          <cite>
            <span class="cite-name">James R.</span>
            <span class="cite-role">Chief Diversity Officer, Financial Services</span>
          </cite>
        </div>

        <div class="pullquote">
          <div class="pq-mark" aria-hidden="true">&ldquo;</div>
          <blockquote>One of the most requested speakers we've hosted. She makes every person in the room feel seen.</blockquote>
          <cite>
            <span class="cite-name">Carla T.</span>
            <span class="cite-role">Director, National Business Conference</span>
          </cite>
        </div>

      </div>
    </div>
  </section>

</Layout>
