---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="MAS Impact Podcast — Hosted by Monica Hernandez"
  description="Conversations with founders, executives, and changemakers on building inclusive, high-impact technology companies — from Latin America to the Fortune 500."
  current="podcast"
>

  <section class="podcast-hero" aria-labelledby="podcast-h1">
    <div class="container">
      <div class="podcast-hero-grid fade-in">

        <div class="phone-wrap" aria-hidden="true">
          <div class="phone-frame">
            <div class="phone-screen phone-screen-image">
              <img src="/Images/Fotos%20Monica/podcastspootify.png" alt="MAS Impact Podcast on Spotify" />
            </div>
          </div>
        </div>

        <div class="podcast-pitch">
          <div class="podcast-rating-badge"><span class="star">★</span> 5.0 <span class="sep">·</span> Listener Rating</div>
          <h1 id="podcast-h1">The MAS Impact<br />Podcast.</h1>
          <p class="lead">Hosted by Monica Hernandez. Real conversations with the founders, executives, and changemakers building the future of enterprise tech.</p>

          <p class="listen-title">Listen on:</p>
          <div class="listen-grid">
            <a class="platform-btn spotify" href="https://open.spotify.com/show/55KaVmlgjUT0uEOX6JfP5m" target="_blank" rel="noopener noreferrer" aria-label="Listen on Spotify">
              <span class="platform-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zm4.6 14.4a.7.7 0 0 1-.95.23c-2.6-1.6-5.86-1.96-9.7-1.08a.7.7 0 1 1-.31-1.36c4.2-.96 7.83-.55 10.74 1.24.33.2.43.64.22.97zm1.23-2.72a.87.87 0 0 1-1.2.29c-2.98-1.83-7.5-2.36-11.02-1.3a.87.87 0 1 1-.51-1.66c4.02-1.22 9.02-.63 12.45 1.47.41.25.54.79.28 1.2zm.11-2.83C14.4 8.78 8.36 8.6 5.13 9.58a1.05 1.05 0 1 1-.61-2c3.74-1.13 10.41-.92 14.34 1.4a1.05 1.05 0 0 1-1.07 1.81z"/></svg>
              </span>
              <span class="platform-meta">
                <span class="platform-kicker">Listen on</span>
                <span class="platform-name">Spotify</span>
              </span>
            </a>
            <a class="platform-btn apple" href="https://podcasts.apple.com/us/podcast/mas-impact-driving-diversity-in-tech-biz/id1699454690" target="_blank" rel="noopener noreferrer" aria-label="Listen on Apple Podcasts">
              <span class="platform-icon" aria-hidden="true">
                <img src="/Images/Enterprise%20and%20event%20logos/applepodcast.png" alt="" />
              </span>
              <span class="platform-meta">
                <span class="platform-kicker">Listen on</span>
                <span class="platform-name">Apple Podcasts</span>
              </span>
            </a>
            <a class="platform-btn youtube" href="https://www.youtube.com/@masglobal6827" target="_blank" rel="noopener noreferrer" aria-label="Watch on YouTube">
              <span class="platform-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.13C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.57A3 3 0 0 0 .5 6.2 31.4 31.4 0 0 0 0 12a31.4 31.4 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.13C4.5 20.5 12 20.5 12 20.5s7.5 0 9.4-.57a3 3 0 0 0 2.1-2.13A31.4 31.4 0 0 0 24 12a31.4 31.4 0 0 0-.5-5.8zM9.75 15.5v-7l6.5 3.5-6.5 3.5z"/></svg>
              </span>
              <span class="platform-meta">
                <span class="platform-kicker">Watch on</span>
                <span class="platform-name">YouTube</span>
              </span>
            </a>
            <a class="platform-btn pocketcasts" href="https://masglobal.captivate.fm/pocketcasts" target="_blank" rel="noopener noreferrer" aria-label="Listen on Pocket Casts">
              <span class="platform-icon" aria-hidden="true">
                <img src="/Images/Enterprise%20and%20event%20logos/pocketcast.png" alt="" />
              </span>
              <span class="platform-meta">
                <span class="platform-kicker">Listen on</span>
                <span class="platform-name">Pocket Casts</span>
              </span>
            </a>
            <a class="platform-btn rss" href="https://feeds.captivate.fm/masglobal/" target="_blank" rel="noopener noreferrer" aria-label="Subscribe via RSS">
              <span class="platform-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M4 4v3.1c8.2 0 14.9 6.7 14.9 14.9H22C22 12.3 13.7 4 4 4zm0 6.1v3c4.9 0 8.8 4 8.8 8.9h3c0-6.5-5.3-11.9-11.8-11.9zM5.7 16.8a2.4 2.4 0 1 0 2.4 2.4 2.4 2.4 0 0 0-2.4-2.4z"/></svg>
              </span>
              <span class="platform-meta">
                <span class="platform-kicker">Subscribe via</span>
                <span class="platform-name">RSS Feed</span>
              </span>
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="podcast-section">
    <div class="container fade-in">
      <div class="eyebrow" style="margin-bottom: 20px;"><span class="eyebrow-text">About the Show</span></div>
      <h2>AI and the leaders<br />building what's next.</h2>
      <p class="lead">MAS Impact brings together expert voices across AI, technology, and leadership. Hosted by Mónica Hernández, Founder and CEO of MAS Global, the podcast features conversations with leaders from top U.S. companies and emerging innovators shaping the future of tech.</p>
      <p class="lead">Each episode focuses on how AI and technology are applied in real-world settings — sharing practical insights, leadership perspectives, and lessons from those building and scaling high-impact organizations.</p>
      <p class="lead">The goal is clear: help leaders navigate complexity and make smarter, more responsible decisions in an AI-driven world.</p>
    </div>
  </section>

  <section class="podcast-section alt" id="episodes">
    <div class="container fade-in">
      <div class="eyebrow" style="margin-bottom: 20px;"><span class="eyebrow-text">Featured Episodes</span></div>
      <h2 style="margin-bottom: 56px;">Episodes worth<br />your commute.</h2>

      <!-- Latest episode spotlight -->
      <article class="latest-episode fade-in" aria-label="Latest episode">
        <div class="ep-cover">
          <img src="/Images/LOGOS%20MAS%20GLOBAL%20-%20MAS%20IMPACT/LOGO%20MAS%20IMPACT.png" alt="" />
        </div>
        <div class="ep-info">
          <div class="ep-eyebrow">Latest · Just Released</div>
          <h3>Building a Nearshore Powerhouse</h3>
          <p class="ep-desc">How Monica scaled MAS Global from Medellín to Fortune 500. The playbook for U.S.–LatAm expansion, told first-hand.</p>
          <div class="ep-meta-row">
            <span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              42 min
            </span>
            <span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              May 2025
            </span>
            <span>EP 01</span>
          </div>
        </div>
        <button class="play-btn" aria-label="Play latest episode">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
        </button>
      </article>

      <div class="episode-grid reveal-stagger">

        <article class="episode-card with-thumb">
          <div class="ep-thumb-img">
            <img src="https://images.unsplash.com/photo-1590602847861-f357a9332bbc?w=800&h=550&fit=crop&q=80" alt="" />
            <div class="ep-play-overlay" aria-hidden="true">
              <div class="play-circle"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></div>
            </div>
          </div>
          <div class="ep-body">
            <div class="ep-num-label">Episode #02</div>
            <h3>Women, Tech &amp; the Boardroom</h3>
            <div class="ep-footer">
              <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>38 min</span>
              <span>Apr 2025</span>
            </div>
          </div>
        </article>

        <article class="episode-card with-thumb">
          <div class="ep-thumb-img">
            <img src="https://images.unsplash.com/photo-1551434678-e076c223a692?w=800&h=550&fit=crop&q=80" alt="" />
            <div class="ep-play-overlay" aria-hidden="true">
              <div class="play-circle"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></div>
            </div>
          </div>
          <div class="ep-body">
            <div class="ep-num-label">Episode #03</div>
            <h3>The AI Transformation Playbook</h3>
            <div class="ep-footer">
              <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>45 min</span>
              <span>Mar 2025</span>
            </div>
          </div>
        </article>

        <article class="episode-card with-thumb">
          <div class="ep-thumb-img">
            <img src="https://images.unsplash.com/photo-1542744173-8e7e53415bb0?w=800&h=550&fit=crop&q=80" alt="" />
            <div class="ep-play-overlay" aria-hidden="true">
              <div class="play-circle"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></div>
            </div>
          </div>
          <div class="ep-body">
            <div class="ep-num-label">Episode #04</div>
            <h3>Inside Fortune 500 Buying</h3>
            <div class="ep-footer">
              <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>40 min</span>
              <span>Feb 2025</span>
            </div>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- Monica as a Guest on Other Shows -->
  <section class="guest-appearances" aria-labelledby="appearances-h2">
    <div class="container fade-in">
      <div class="eyebrow"><span class="eyebrow-text">Monica on Other Shows</span></div>
      <h2 id="appearances-h2">Recent appearances.</h2>

      <a class="appearance-card" href="https://www.youtube.com/watch?v=6vPdkQxoaDg" target="_blank" rel="noopener noreferrer" aria-label="Watch on YouTube">
        <div class="appearance-thumb">
          <iframe
            src="https://www.youtube.com/embed/6vPdkQxoaDg"
            title="Growth and Drive Without Limits — Colombian-American Chamber of Commerce Miami"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"></iframe>
        </div>
        <div class="appearance-body">
          <span class="show-kicker">Podcast Appearance</span>
          <h3>Growth and Drive Without Limits</h3>
          <p class="show-host">Colombian-American Chamber of Commerce Miami</p>
          <span class="show-cta">
            Watch on YouTube
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17l9.2-9.2M17 17V7H7"/></svg>
          </span>
        </div>
      </a>
    </div>
  </section>

  <!-- Want to be a Guest? — Nick Vujicic style -->
  <section class="guest-section" aria-labelledby="guest-h2">
    <div class="container">
      <div class="guest-grid">
        <div class="guest-text fade-in">
          <h2 id="guest-h2">Want to be<br />a Guest?</h2>
          <div class="guest-divider" aria-hidden="true"></div>
          <p>If you're a founder, executive, or operator shaping how enterprise technology, leadership, or inclusive growth gets built — Monica wants to hear your story. The MAS Impact Podcast is where the people behind the headlines come to speak plainly.</p>
          <a class="btn btn-dark" href="/book" role="button">Request to be a Guest</a>
        </div>
        <div class="guest-image fade-in" aria-hidden="true">
          <img src="/Images/Fotos%20Monica/Monicas%20miling.png" alt="" />
        </div>
      </div>
    </div>
  </section>

</Layout>
