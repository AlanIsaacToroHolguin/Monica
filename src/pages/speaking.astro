---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Speaking — Monica Hernandez"
  description="Keynotes, workshops and panels from Monica Hernandez — AI, leadership, and how to pitch a corporation."
  current="speaking"
>
<div class="speaking-page">

  <!-- Hero — full-bleed photo carousel that powers the page -->
  <section class="speaking-hero-slider" aria-label="Monica on stage">
    <div class="swiper" id="monica-swiper">
      <div class="swiper-wrapper">
        <div class="swiper-slide"><img src="/Images/Speaking/1.png" alt="Monica on stage" /></div>
        <div class="swiper-slide"><img src="/Images/Speaking/2.png" alt="Monica on stage" /></div>
        <div class="swiper-slide"><img src="/Images/Speaking/3.png" alt="Monica on stage" /></div>
        <div class="swiper-slide"><img src="/Images/Speaking/4.png" alt="Monica on stage" /></div>
        <div class="swiper-slide"><img src="/Images/Speaking/5.png" alt="Monica on stage" /></div>
      </div>
    </div>

    <div class="speaking-hero-overlay">
      <div class="container">
        <div class="hero-eyebrow"><span>20+ Years on the Front Lines</span></div>
        <h1>Real experience.<br />Relevant insights.</h1>
        <p>A founder, a consultant, an immigrant. Monica speaks from inside enterprise — not around it.</p>
        <a class="btn btn-red btn-pill" href="/book" role="button">Book Monica</a>
      </div>
    </div>

    <div class="speaking-hero-controls">
      <button class="swiper-btn" id="monica-prev" aria-label="Previous photo">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <div class="swiper-count"><span id="monica-current">01</span> / <span id="monica-total">05</span></div>
      <button class="swiper-btn" id="monica-next" aria-label="Next photo">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>
      </button>
    </div>

    <div class="speaking-hero-pagination" id="monica-pagination" aria-hidden="true"></div>
  </section>

  <!-- Who This Is For -->
  <section class="who-band" aria-labelledby="speaking-who-h2">
    <div class="container fade-in">
      <div class="eyebrow"><span class="eyebrow-text">Audience</span></div>
      <div class="who-inner">
        <h2 id="speaking-who-h2">Built for leaders<br />navigating real complexity.</h2>
        <p>AI adoption. Workforce transformation. Diverse leadership pipelines. Monica's sessions are for C-suite, HR, and technology teams making decisions that actually move the needle.</p>
      </div>
    </div>
  </section>

  <!-- Speaking Topics (dark section with white cards) -->
  <section class="section topics-dark-section" aria-labelledby="speaking-topics-h2">
    <div class="container">
      <div class="eyebrow fade-in"><span class="eyebrow-text">Speaking Topics</span></div>
      <h2 id="speaking-topics-h2" class="fade-in">Three topics.<br />One thread: clarity.</h2>

      <div class="topics-list reveal-stagger">

        <article class="topic-card">
          <div class="topic-num">01</div>
          <div class="topic-body">
            <h3>AI in the Enterprise</h3>
            <p class="for-line">For tech executives navigating AI strategy and digital transformation.</p>
            <p class="walks-label">Audience walks away with</p>
            <ul>
              <li>A jargon-free view of where AI creates real value.</li>
              <li>Frameworks for assessing AI readiness across people, process, and infrastructure.</li>
              <li>Clear-eyed perspective on talent, risk, and ROI from someone who's delivered for Fortune 500.</li>
            </ul>
          </div>
        </article>

        <article class="topic-card">
          <div class="topic-num">02</div>
          <div class="topic-body">
            <h3>Leadership That Scales</h3>
            <p class="for-line">For executives and HR leaders building diverse, distributed teams.</p>
            <p class="walks-label">Audience walks away with</p>
            <ul>
              <li>Practical tools for leading across cultures and time zones.</li>
              <li>An honest look at what retention and belonging actually require.</li>
              <li>Insight from a leader who scaled a global company over 20+ years.</li>
            </ul>
          </div>
        </article>

        <article class="topic-card">
          <div class="topic-num">03</div>
          <div class="topic-body">
            <h3>Pitch a Corporation</h3>
            <p class="for-line">For founders, supplier diversity programs, and minority-owned businesses chasing enterprise clients.</p>
            <p class="walks-label">Audience walks away with</p>
            <ul>
              <li>A clear map of how enterprise buying decisions get made.</li>
              <li>How to position as a credible partner — not just a vendor.</li>
              <li>Practical steps to earn access and keep it.</li>
            </ul>
            <p class="topic-note">Monica has been on both sides of the table.</p>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- Selected Stages -->
  <section class="stages-band" aria-labelledby="stages-h2">
    <div class="container">
      <div class="eyebrow eyebrow-center fade-in" style="margin-bottom: 16px;"><span class="eyebrow-text">Selected Stages</span></div>
      <h2 id="stages-h2" class="fade-in" style="text-align: center; margin-bottom: 48px;">Stages she's spoken on.</h2>
      <div class="logo-row fade-in">
        <div class="logo-item"><span>JPMorgan Chase</span></div>
        <div class="logo-item"><span>Dexcom</span></div>
        <div class="logo-item"><img src="/Images/Enterprise%20and%20event%20logos/WPO%20logo.webp" alt="WPO" /></div>
        <div class="logo-item"><img src="/Images/Enterprise%20and%20event%20logos/wbenc-logo.jpg" alt="WBENC" /></div>
        <div class="logo-item"><img src="/Images/Enterprise%20and%20event%20logos/AzureDevOps.webp" alt="Microsoft Azure" /></div>
        <div class="logo-item"><span>.NET Conf</span></div>
        <div class="logo-item"><span>RutaN Medellín</span></div>
        <div class="logo-item"><span>LBAN</span></div>
        <div class="logo-item"><span>JCI Women's Business Network</span></div>
        <div class="logo-item"><span>Latino Chamber of Commerce</span></div>
        <div class="logo-item"><img src="/Images/Enterprise%20and%20event%20logos/Latinas%20in%20Tech%20logo.jpg" alt="Latinas in Tech" /></div>
        <div class="logo-item"><span>Tampa Tech Week</span></div>
      </div>
    </div>
  </section>

</div><!-- /.speaking-page -->

<script>
  import Swiper from 'swiper';
  import { Navigation, Keyboard, Autoplay, EffectFade } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/effect-fade';

  function initSpeakingSwiper() {
    const el = document.querySelector('#monica-swiper');
    const nextBtn = document.getElementById('monica-next');
    const prevBtn = document.getElementById('monica-prev');
    const pagination = document.getElementById('monica-pagination');
    const current = document.getElementById('monica-current');
    const total = document.getElementById('monica-total');
    if (!el) return;

    const swiper = new Swiper(el, {
      modules: [Navigation, Keyboard, Autoplay, EffectFade],
      slidesPerView: 1,
      effect: 'fade',
      fadeEffect: { crossFade: true },
      grabCursor: true,
      loop: true,
      keyboard: { enabled: true },
      speed: 800,
      navigation: { nextEl: nextBtn, prevEl: prevBtn },
      autoplay: { delay: 3000, disableOnInteraction: false }
    });

    const real = el.querySelectorAll('.swiper-slide:not(.swiper-slide-duplicate)').length;
    if (total) total.textContent = String(real).padStart(2, '0');

    // Build pagination dots
    if (pagination) {
      pagination.innerHTML = '';
      for (let i = 0; i < real; i++) {
        const dot = document.createElement('span');
        dot.className = 'dot' + (i === 0 ? ' active' : '');
        dot.addEventListener('click', () => swiper.slideToLoop(i));
        pagination.appendChild(dot);
      }
    }

    const update = () => {
      const idx = (swiper.realIndex ?? swiper.activeIndex);
      if (current) current.textContent = String(idx + 1).padStart(2, '0');
      if (pagination) {
        pagination.querySelectorAll('.dot').forEach((d, i) => d.classList.toggle('active', i === idx));
      }
    };
    swiper.on('slideChange', update);
    update();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSpeakingSwiper);
  } else {
    initSpeakingSwiper();
  }
</script>

</Layout>
