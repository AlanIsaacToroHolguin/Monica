---
const links = [
  { href: '/', label: 'Home' },
  { href: '/speaking', label: 'Speaking' },
  { href: '/about', label: 'About Monica' },
  { href: '/podcast', label: 'MAS Impact Podcast' },
  { href: '/book', label: 'Book Monica' }
];
const year = new Date().getFullYear();
---

<footer aria-label="Site footer">
  <div class="container">
    <div class="footer-inner">

      <div class="footer-left">
        <div>
          <p class="footer-name">Monica Hernandez</p>
          <p class="footer-title">Founder &amp; CEO, MAS Global</p>
        </div>
        <div class="footer-divider" aria-hidden="true"></div>
        <p class="footer-tagline">Ready to bring Monica to your stage?</p>
        <a class="btn btn-red" href="/book">Book Monica</a>
      </div>

      <div class="footer-right">
        <nav class="footer-nav" aria-label="Footer navigation">
          {links.map((l) => <a class="nav-link" href={l.href}>{l.label}</a>)}
        </nav>

        <div class="footer-connect">
          <span class="connect-eyebrow">Let's Connect!</span>

          <div class="footer-social">
            <a href="#" target="_blank" rel="noopener noreferrer" aria-label="Monica on LinkedIn">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.95v5.66H9.36V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.6 0 4.26 2.37 4.26 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/>
              </svg>
            </a>
            <a href="#" target="_blank" rel="noopener noreferrer" aria-label="Monica on Instagram">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="5"/>
                <circle cx="12" cy="12" r="4"/>
                <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
              </svg>
            </a>
            <a href="https://www.youtube.com/@masglobal6827" target="_blank" rel="noopener noreferrer" aria-label="MAS Global on YouTube">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M23.5 6.2a3 3 0 0 0-2.1-2.13C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.57A3 3 0 0 0 .5 6.2 31.4 31.4 0 0 0 0 12a31.4 31.4 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.13C4.5 20.5 12 20.5 12 20.5s7.5 0 9.4-.57a3 3 0 0 0 2.1-2.13A31.4 31.4 0 0 0 24 12a31.4 31.4 0 0 0-.5-5.8zM9.75 15.5v-7l6.5 3.5-6.5 3.5z"/>
              </svg>
            </a>
          </div>

          <div class="footer-contact">
            <div>
              <span class="contact-label">Email</span>
              <a href="mailto:monica@masglobalconsulting.com">monica@masglobalconsulting.com</a>
            </div>
            <div>
              <span class="contact-label">US Office Headquarters</span>
              3030 N Rocky Point Dr, S730<br />
              Tampa, FL 33607, United States
            </div>
          </div>
        </div>
      </div>

      <p class="footer-copy">&copy; {year} Monica Hernandez. All rights reserved.</p>

    </div>
  </div>
</footer>
